# ====================================================
# MCP AGENTIC GATEWAY - ENVIRONMENT CONFIGURATION
# ====================================================

# ── API Gateway Configuration ───────────────────────
PORT=8000
HOST=0.0.0.0
AI_MODEL_API_KEY=your-groq-or-anthropic-key

# ── Jira Configuration ──────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# ── GitHub Configuration ────────────────────────────
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repository-name

# ── Slack Configuration ─────────────────────────────
SLACK_BASE_URL=https://slack.com
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── Google Sheets Configuration ─────────────────────
SHEETS_BASE_URL=https://sheets.googleapis.com
SHEETS_DOCUMENT_ID=your-google-sheet-id
# Path to your Google Cloud Service Account JSON file (e.g., ./sheets-service-account.json)
# GOOGLE_APPLICATION_CREDENTIALS=your-service-account.json
